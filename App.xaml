<Application x:Class="SpotCont.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#10141B" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#1B222D" />
        <SolidColorBrush x:Key="SearchBarBorderBrush" Color="#222B37" />
        <SolidColorBrush x:Key="HoverBrush" Color="#18202A" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#1E2834" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3A82F7" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B1B8C4" />
        <SolidColorBrush x:Key="TertiaryTextBrush" Color="#8C94A2" />
        <SolidColorBrush x:Key="ResultIconBackgroundBrush" Color="#151A22" />
        <SolidColorBrush x:Key="ResultIconBorderBrush" Color="#263041" />
        <SolidColorBrush x:Key="ContextMenuBackgroundBrush" Color="#0C1016" />
        <SolidColorBrush x:Key="ContextMenuBorderBrush" Color="#1B222D" />
        <SolidColorBrush x:Key="ContextMenuHoverBrush" Color="#203247" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Application.Resources>
</Application>
