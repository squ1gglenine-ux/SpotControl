<Window x:Class="SpotCont.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpotCont"
        Width="920"
        Height="{Binding LauncherHeight, Mode=OneWay}"
        MinWidth="920"
        MaxWidth="920"
        MinHeight="{Binding LauncherHeight, Mode=OneWay}"
        MaxHeight="{Binding LauncherHeight, Mode=OneWay}"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="14"
        ShowInTaskbar="False"
        Topmost="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        Deactivated="Window_Deactivated"
        PreviewTextInput="Window_PreviewTextInput"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource TertiaryTextBrush}" />
            <Setter Property="Opacity" Value="0.24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Margin="1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.42" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Opacity" Value="0.56" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Width="{TemplateBinding Width}"
                                      Margin="0,6,1,6"
                                      Background="Transparent">
                                    <Track x:Name="PART_Track"
                                           Focusable="False"
                                           IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                          Style="{StaticResource ScrollBarPageButtonStyle}" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb MinHeight="26"
                                                   Style="{StaticResource ScrollBarThumbStyle}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                          Style="{StaticResource ScrollBarPageButtonStyle}" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="0" />
                    <Setter Property="Opacity" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="60" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <EventSetter Event="MouseEnter" Handler="ResultItem_MouseEnter" />
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ResultItem_PreviewMouseLeftButtonUp" />
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ResultItem_PreviewMouseRightButtonDown" />
            <EventSetter Event="ContextMenuOpening" Handler="ResultItem_ContextMenuOpening" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Height="60"
                              SnapsToDevicePixels="True">
                            <Border x:Name="ItemBackground"
                                    Background="Transparent" />

                            <Border x:Name="AccentBar"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource AccentBrush}"
                                    Visibility="Collapsed" />

                            <ContentPresenter />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource SelectedBrush}" />
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ContextMenuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ContextMenuBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="Transparent"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}"
                                    ClipToBounds="True">
                                <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Margin="1"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="MenuItemAccent"
                                        Grid.Column="0"
                                        Margin="0,4,0,4"
                                        CornerRadius="2"
                                        Background="{DynamicResource AccentBrush}"
                                        Opacity="0" />

                                <ContentPresenter Grid.Column="2"
                                                  Margin="0,-1,12,0"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  TextBlock.LineHeight="16"
                                                  TextBlock.LineStackingStrategy="BlockLineHeight"
                                                  RecognizesAccessKey="True"
                                                  ContentSource="Header" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder"
                                        Property="Background"
                                        Value="{DynamicResource ContextMenuHoverBrush}" />
                                <Setter TargetName="MenuItemAccent"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootSurface"
            Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="0,0,8,8"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScaleTransform"
                            ScaleX="1"
                            ScaleY="1" />
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="14"
                              ShadowDepth="0"
                              Color="#000000"
                              Opacity="0.28" />
        </Border.Effect>

        <Border x:Name="ContentClipHost"
                CornerRadius="0,0,7,7"
                Background="{DynamicResource WindowBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="336" />
                </Grid.RowDefinitions>

            <Border BorderBrush="{DynamicResource SearchBarBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource WindowBackgroundBrush}">
                <Grid Margin="16,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="92" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="SearchTextBox_TextChanged" />

                        <TextBlock IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType"
                                   Visibility="{Binding HasAutocompleteSuffix, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Run Text="{Binding Query, Mode=OneWay}" Foreground="Transparent" />
                            <Run Text="{Binding AutocompleteSuffix, Mode=OneWay}"
                                 FontStyle="Italic"
                                 Foreground="{DynamicResource SecondaryTextBrush}" />
                        </TextBlock>

                        <TextBlock IsHitTestVisible="False"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                   FontSize="16"
                                   Text="Type here to search">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Query}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="16" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right"
                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                   FontSize="12"
                                   Text="{Binding CurrentTimeText}" />

                        <Image Grid.Column="2"
                               Width="16"
                               Height="16"
                               Opacity="0.72"
                               Source="{Binding SearchIconSource, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="ResultsListBox"
                             Grid.Column="0"
                             ItemsSource="{Binding Results}"
                             SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                             Visibility="{Binding HasResults, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                             SelectionChanged="ResultsListBox_SelectionChanged"
                             PreviewMouseWheel="ResultsListBox_PreviewMouseWheel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="12,8,12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="48" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="36"
                                            Height="36"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource ResultIconBackgroundBrush}"
                                            BorderBrush="{DynamicResource ResultIconBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            SnapsToDevicePixels="True">
                                        <Image HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               SnapsToDevicePixels="True"
                                               Source="{Binding IconSource}">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Width" Value="24" />
                                                    <Setter Property="Height" Value="24" />
                                                    <Setter Property="Margin" Value="0" />
                                                    <Setter Property="Stretch" Value="Uniform" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UsesThumbnailPreview}" Value="True">
                                                            <Setter Property="Width" Value="36" />
                                                            <Setter Property="Height" Value="36" />
                                                            <Setter Property="Stretch" Value="UniformToFill" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Border>

                                    <Grid Grid.Column="2"
                                          VerticalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="14"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,2,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding Subtitle}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>

                                    <TextBlock Grid.Column="3"
                                               Width="48"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               TextAlignment="Right"
                                               FontSize="12"
                                               Foreground="{DynamicResource TertiaryTextBrush}"
                                               Text="{Binding ShortcutLabel}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Column="1"
                            Width="1"
                            Margin="0,10,0,10"
                            Background="{DynamicResource WindowBorderBrush}"
                            Visibility="{Binding HasFilePreview, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Border x:Name="PreviewPanelHost"
                            Grid.Column="2"
                            Width="290"
                            Padding="12,12,12,10"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            Visibility="{Binding HasFilePreview, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="PreviewPanelScaleTransform"
                                            ScaleX="1"
                                            ScaleY="1" />
                        </Border.RenderTransform>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      PreviewMouseWheel="PreviewPanelScrollViewer_PreviewMouseWheel">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="{Binding FilePreviewImageContainerHeight, Mode=OneWay}" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Width="{Binding FilePreviewImageContainerWidth, Mode=OneWay}"
                                        Height="{Binding FilePreviewImageContainerHeight, Mode=OneWay}"
                                        HorizontalAlignment="{Binding FilePreviewImageContainerAlignment, Mode=OneWay}"
                                        Background="{DynamicResource ResultIconBackgroundBrush}"
                                        BorderBrush="{DynamicResource ResultIconBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        ClipToBounds="True">
                                    <Image Source="{Binding FilePreviewImageSource, Mode=OneWay}"
                                           Stretch="{Binding FilePreviewImageStretch, Mode=OneWay}"
                                           MaxWidth="{Binding FilePreviewImageMaxDimension, Mode=OneWay}"
                                           MaxHeight="{Binding FilePreviewImageMaxDimension, Mode=OneWay}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>

                                <TextBlock Grid.Row="1"
                                           Margin="0,10,0,0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding FilePreviewTitle, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Row="2"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           Text="{Binding FilePreviewPath, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           TextTrimming="WordEllipsis"
                                           Cursor="Hand"
                                           MouseLeftButtonUp="PreviewPath_MouseLeftButtonUp">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Grid.Row="3"
                                            Margin="0,10,0,0">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding FilePreviewType, Mode=OneWay}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding FilePreviewSize, Mode=OneWay}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding FilePreviewModified, Mode=OneWay}" />
                                </StackPanel>

                                <Border Grid.Row="4"
                                        Margin="0,10,0,0"
                                        Padding="8"
                                        CornerRadius="8"
                                        Background="{DynamicResource ResultIconBackgroundBrush}"
                                        BorderBrush="{DynamicResource ResultIconBorderBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding HasFilePreviewSnippet, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding FilePreviewSnippet, Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
